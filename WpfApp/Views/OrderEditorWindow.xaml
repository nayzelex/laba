<Window x:Class="WpfApp.Views.OrderEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование заказа" 
        Height="450" 
        Width="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Icon="/images/Icon.ico">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="5,5,5,2"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="5,2,5,10"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="5,2,5,10"/>
        </Style>
        <Style TargetType="DatePicker">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="5,2,5,10"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Margin" Value="5,10,5,5"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Background="White" Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Информация о заказе" 
                   FontSize="18" FontWeight="Bold" TextAlignment="Center" Margin="0,0,0,15"/>

        <!-- Артикул (ID заказа) -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Артикул заказа:" VerticalAlignment="Center"/>
        <TextBox x:Name="txtOrderId" Grid.Row="1" Grid.Column="1" 
                 IsReadOnly="True" Background="#F0F0F0" IsEnabled="False"/>

        <!-- Статус заказа -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Статус заказа:*" VerticalAlignment="Center"/>
        <ComboBox x:Name="cmbStatus" Grid.Row="2" Grid.Column="1">
            <ComboBoxItem Content="Новый"/>
            <ComboBoxItem Content="Завершен"/>
        </ComboBox>

        <!-- Адрес пункта выдачи -->
        <TextBlock Grid.Row="3" Grid.Column="0" Text="Адрес пункта выдачи:*" VerticalAlignment="Center"/>
        <ComboBox x:Name="cmbPickupPoint" Grid.Row="3" Grid.Column="1" 
                  DisplayMemberPath="Address" SelectedValuePath="Id"/>

        <!-- Дата заказа -->
        <TextBlock Grid.Row="4" Grid.Column="0" Text="Дата заказа:*" VerticalAlignment="Center"/>
        <DatePicker x:Name="dpOrderDate" Grid.Row="4" Grid.Column="1" 
                    SelectedDateFormat="Short" Margin="5,2,5,10"/>

        <!-- Дата выдачи (доставки) -->
        <TextBlock Grid.Row="5" Grid.Column="0" Text="Дата доставки:" VerticalAlignment="Center"/>
        <DatePicker x:Name="dpDeliveryDate" Grid.Row="5" Grid.Column="1" 
                    SelectedDateFormat="Short" Margin="5,2,5,10"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="6" Grid.ColumnSpan="2" Orientation="Horizontal" 
                    HorizontalAlignment="Center" Margin="0,20,0,10">
            <Button x:Name="btnSave" Content="Сохранить" Click="Save_Click" 
                    Background="#00FA9A" Width="120" FontWeight="Bold"/>
            <Button x:Name="btnDelete" Content="Удалить" Click="Delete_Click" 
                    Background="#FF6B6B" Width="120" Visibility="Collapsed"/>
            <Button Content="Отмена" Click="Cancel_Click" Width="120"/>
        </StackPanel>
    </Grid>
</Window>