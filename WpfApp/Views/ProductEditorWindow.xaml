<Window x:Class="WpfApp.Views.ProductEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Информация о товаре" 
        Height="700" 
        Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Icon="/images/Icon.ico">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="5,5,5,2"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="5,2,5,10"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="5,2,5,10"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Margin" Value="5,10,5,5"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Background="White" Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="130"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Фото -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Фото:" VerticalAlignment="Center"/>
        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="5,2,5,10">
            <Image x:Name="imgProduct" Width="100" Height="100" Stretch="Uniform" 
                   Source="/images/picture.png" Margin="0,0,10,0"/>
            <Button x:Name="btnLoadImage" Content="Загрузить фото" Click="LoadImage_Click" 
                    Width="100" Height="30" FontSize="11" Background="#7FFF00"/>
        </StackPanel>

        <!-- Артикул -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Артикул:" VerticalAlignment="Center"/>
        <TextBox x:Name="txtArticle" Grid.Row="1" Grid.Column="1" IsReadOnly="{Binding IsEditing}"/>

        <!-- Наименование -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Наименование:*" VerticalAlignment="Center"/>
        <TextBox x:Name="txtName" Grid.Row="2" Grid.Column="1"/>

        <!-- Категория -->
        <TextBlock Grid.Row="3" Grid.Column="0" Text="Категория:*" VerticalAlignment="Center"/>
        <ComboBox x:Name="cmbCategory" Grid.Row="3" Grid.Column="1" 
                  DisplayMemberPath="Name" SelectedValuePath="Id"/>

        <!-- Описание -->
        <TextBlock Grid.Row="4" Grid.Column="0" Text="Описание:" VerticalAlignment="Top"/>
        <TextBox x:Name="txtDescription" Grid.Row="4" Grid.Column="1" Height="60" 
                 TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>

        <!-- Производитель -->
        <TextBlock Grid.Row="5" Grid.Column="0" Text="Производитель:*" VerticalAlignment="Center"/>
        <ComboBox x:Name="cmbManufacturer" Grid.Row="5" Grid.Column="1" 
                  DisplayMemberPath="Name" SelectedValuePath="Id"/>

        <!-- Поставщик -->
        <TextBlock Grid.Row="6" Grid.Column="0" Text="Поставщик:*" VerticalAlignment="Center"/>
        <ComboBox x:Name="cmbSupplier" Grid.Row="6" Grid.Column="1" 
                  DisplayMemberPath="Name" SelectedValuePath="Id"/>

        <!-- Цена -->
        <TextBlock Grid.Row="7" Grid.Column="0" Text="Цена (руб.):*" VerticalAlignment="Center"/>
        <TextBox x:Name="txtPrice" Grid.Row="7" Grid.Column="1"/>

        <!-- Единица измерения -->
        <TextBlock Grid.Row="8" Grid.Column="0" Text="Ед. измерения:*" VerticalAlignment="Center"/>
        <TextBox x:Name="txtUnit" Grid.Row="8" Grid.Column="1" Text="шт."/>

        <!-- Количество -->
        <TextBlock Grid.Row="9" Grid.Column="0" Text="Количество:*" VerticalAlignment="Center"/>
        <TextBox x:Name="txtStockQuantity" Grid.Row="9" Grid.Column="1"/>

        <!-- Скидка -->
        <TextBlock Grid.Row="10" Grid.Column="0" Text="Скидка (%):" VerticalAlignment="Center"/>
        <TextBox x:Name="txtDiscount" Grid.Row="10" Grid.Column="1" Text="0"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="11" Grid.ColumnSpan="2" Orientation="Horizontal" 
                    HorizontalAlignment="Center" Margin="0,20,0,10">
            <Button x:Name="btnSave" Content="Сохранить" Click="Save_Click" 
                    Background="#00FA9A" Width="120" FontWeight="Bold"/>
            <Button x:Name="btnDelete" Content="Удалить" Click="Delete_Click" 
                    Background="#FF6B6B" Width="120" Visibility="Collapsed"/>
            <Button x:Name="btnCancel" Content="Отмена" Click="Cancel_Click" Width="120"/>
        </StackPanel>
    </Grid>
</Window>