<Window x:Class="WpfApp.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизация - Обувной магазин" 
        Height="450" 
        Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <!-- УБЕРИТЕ Icon="/Resources/icon.ico" если он есть -->

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель с логотипом -->
        <Border Grid.Row="0" Background="#7FFF00" Height="100">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <!-- ИЗМЕНИТЕ ПУТЬ К ЛОГОТИПУ на /images/logo.png -->
                <Image Source="/images/icon.png" Height="60" Margin="0,0,20,0"/>
                <TextBlock Text="Обувной магазин" FontSize="24" FontFamily="Times New Roman" 
                           FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Форма авторизации -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="50,0">
            <TextBlock Text="Вход в систему" FontSize="20" FontFamily="Times New Roman" 
                       FontWeight="Bold" TextAlignment="Center" Margin="0,0,0,30"/>

            <TextBlock Text="Логин (Email):" FontFamily="Times New Roman" FontSize="14"/>
            <TextBox x:Name="txtLogin" />

            <TextBlock Text="Пароль:" FontFamily="Times New Roman" FontSize="14"/>
            <PasswordBox x:Name="txtPassword"/>

            <Button Content="Войти" Click="Login_Click" Background="#00FA9A" Foreground="Black" FontWeight="Bold"/>
            <Button Content="Войти как гость" Click="Guest_Click" Background="#7FFF00" Foreground="Black"/>
        </StackPanel>
    </Grid>
</Window>