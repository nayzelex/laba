<Window x:Class="WpfApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:WpfApp.Converters"
        Title="Обувной магазин - Список товаров" 
        Height="700" 
        Width="1200"
        WindowStartupLocation="CenterScreen"
        Icon="/images/Icon.ico">

    <Window.Resources>
        <!-- Конвертеры -->
        <converters:DiscountToColorConverter x:Key="DiscountToColorConverter"/>
        <converters:StockToColorConverter x:Key="StockToColorConverter"/>

        <!-- Стиль для ListBoxItem (прямоугольный блок) -->
        <Style TargetType="ListBoxItem">
            <Setter Property="Height" Value="120"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderBrush" Value="#DDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <!-- Подсветка при скидке > 15% -->
                <DataTrigger Binding="{Binding DiscountPercent}" Value="16">
                    <Setter Property="Background" Value="#2E8B57"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding DiscountPercent}" Value="17">
                    <Setter Property="Background" Value="#2E8B57"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding DiscountPercent}" Value="18">
                    <Setter Property="Background" Value="#2E8B57"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding DiscountPercent}" Value="19">
                    <Setter Property="Background" Value="#2E8B57"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding DiscountPercent, Converter={StaticResource DiscountToColorConverter}}" Value="True">
                    <Setter Property="Background" Value="#2E8B57"/>
                </DataTrigger>
                <!-- Подсветка при отсутствии на складе -->
                <DataTrigger Binding="{Binding StockQuantity}" Value="0">
                    <Setter Property="Background" Value="LightBlue"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Шаблон для отображения товара -->
        <DataTemplate x:Key="ProductTemplate">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <!-- Левая треть - фото -->
                    <ColumnDefinition Width="2*"/>
                    <!-- Средняя треть - информация -->
                    <ColumnDefinition Width="200"/>
                    <!-- Правая треть - скидка -->
                </Grid.ColumnDefinitions>

                <!-- Левая часть: Фото -->
                <Border Grid.Column="0" Background="#F5F5F5" Margin="5">
                    <Image Source="{Binding PhotoPath, FallbackValue=/images/picture.png}" 
                           Width="90" Height="90" Stretch="Uniform" Margin="5"/>
                </Border>

                <!-- Средняя часть: Информация о товаре -->
                <StackPanel Grid.Column="1" Margin="10,5">
                    <!-- Категория | Наименование -->
                    <TextBlock FontSize="14" FontWeight="Bold">
                        <Run Text="{Binding Category.Name}"/> | <Run Text="{Binding Name}"/>
                    </TextBlock>

                    <!-- Описание -->
                    <TextBlock Text="Описание товара:" FontSize="11" FontWeight="Bold" Margin="0,5,0,0"/>
                    <TextBlock Text="{Binding Description}" FontSize="11" 
                               TextWrapping="Wrap" MaxHeight="30" Margin="0,0,0,5"/>

                    <!-- Производитель -->
                    <TextBlock FontSize="11">
                        <Run Text="Производитель:" FontWeight="Bold"/> <Run Text="{Binding Manufacturer.Name}"/>
                    </TextBlock>

                    <!-- Поставщик -->
                    <TextBlock FontSize="11">
                        <Run Text="Поставщик:" FontWeight="Bold"/> <Run Text="{Binding Supplier.Name}"/>
                    </TextBlock>

                    <!-- Цена -->
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <TextBlock Text="Цена:" FontWeight="Bold" FontSize="12"/>
                        <TextBlock Margin="5,0,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="{Binding Price, StringFormat={}{0:F2} руб.}"/>
                                    <Setter Property="Foreground" Value="Black"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DiscountPercent}" Value="0">
                                            <Setter Property="TextDecorations" Value="None"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding DiscountPercent, Converter={StaticResource DiscountToColorConverter}}" Value="True">
                                            <Setter Property="TextDecorations" Value="Strikethrough"/>
                                            <Setter Property="Foreground" Value="Red"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <!-- Единица измерения -->
                    <TextBlock FontSize="11">
                        <Run Text="Единица измерения:" FontWeight="Bold"/> <Run Text="{Binding Unit}"/>
                    </TextBlock>

                    <!-- Количество на складе -->
                    <TextBlock FontSize="11">
                        <Run Text="Количество на складе:" FontWeight="Bold"/> <Run Text="{Binding StockQuantity}"/>
                    </TextBlock>
                </StackPanel>

                <!-- Правая часть: Скидка -->
                <Border Grid.Column="2" Background="#F9F9F9" Margin="5" CornerRadius="5" HorizontalAlignment="Right" Width="180">
                    <StackPanel Margin="10" VerticalAlignment="Center">
                        <TextBlock Text="Действующая скидка" FontSize="11" FontWeight="Bold" 
                                   TextAlignment="Center" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding DiscountPercent, StringFormat={}{0}%}" 
                                   FontSize="16" FontWeight="Bold" 
                                   TextAlignment="Center" Margin="0,5,0,5"/>

                        <!-- Цена со скидкой -->
                        <Border Background="#00FA9A" CornerRadius="5" Padding="5" Margin="0,5">
                            <TextBlock Text="{Binding FinalPrice, StringFormat={}{0:F2} руб.}" 
                                       FontSize="14" FontWeight="Bold" 
                                       TextAlignment="Center" Foreground="Black"/>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Border Grid.Row="0" Background="#7FFF00" Height="80">
            <Grid>
                <StackPanel Orientation="Horizontal" Margin="20,0">
                    <Image Source="/images/Icon.png" Height="50" Margin="0,0,20,0"/>
                    <TextBlock Text="Обувной магазин" FontSize="20" FontFamily="Times New Roman" 
                               FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,20,0" VerticalAlignment="Center">
                    <TextBlock x:Name="txtUserInfo" FontSize="14" FontFamily="Times New Roman" 
                               VerticalAlignment="Center" Margin="0,0,15,0"/>
                    <Button x:Name="btnLogout" Content="Выйти" Click="Logout_Click" 
                            Background="#00FA9A" Width="80" Height="30" FontSize="12"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Панель фильтрации -->
        <Border Grid.Row="1" Background="#F0F0F0" BorderBrush="#DDD" BorderThickness="0,0,0,1"
                x:Name="panelFilters" Visibility="Collapsed">
            <StackPanel Orientation="Horizontal" Margin="10" HorizontalAlignment="Center">
                <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="5,0"/>
                <TextBox x:Name="txtSearch" Width="200" TextChanged="SearchText_Changed"/>

                <TextBlock Text="Фильтр по поставщику:" VerticalAlignment="Center" Margin="15,0,5,0"/>
                <ComboBox x:Name="cmbSupplier" Width="150" SelectionChanged="SupplierFilter_Changed"/>

                <TextBlock Text="Сортировка по количеству:" VerticalAlignment="Center" Margin="15,0,5,0"/>
                <ComboBox x:Name="cmbSort" Width="120" SelectionChanged="Sort_Changed">
                    <ComboBoxItem Content="Нет"/>
                    <ComboBoxItem Content="По возрастанию"/>
                    <ComboBoxItem Content="По убыванию"/>
                </ComboBox>

                <Button x:Name="btnAddProduct" Content="Добавить товар" Click="AddProduct_Click" 
                        Background="#00FA9A" Width="120" Margin="20,0,0,0" Visibility="Collapsed"/>
                <Button x:Name="btnOrders" Content="Заказы" Click="Orders_Click" 
                        Background="#00FA9A" Width="100" Margin="10,0,0,0" Visibility="Collapsed"/>
            </StackPanel>
        </Border>

        <!-- Список товаров (ListBox вместо DataGrid) -->
        <ListBox Grid.Row="2" x:Name="lbProducts" 
         ItemTemplate="{StaticResource ProductTemplate}"
         MouseDoubleClick="Product_DoubleClick"
         Background="White"
         BorderThickness="0"
         ScrollViewer.VerticalScrollBarVisibility="Auto"
         ScrollViewer.CanContentScroll="False"
         VirtualizingPanel.ScrollUnit="Pixel"/>

        <!-- Нижняя панель -->
        <Border Grid.Row="3" Background="#7FFF00" Height="40">
            <TextBlock x:Name="txtStatus" Text="Готов" FontSize="12" FontFamily="Times New Roman" 
                       VerticalAlignment="Center" Margin="10,0"/>
        </Border>
    </Grid>
</Window>