<Window x:Class="WpfApp.Views.OrdersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление заказами" 
        Height="500" 
        Width="800"
        WindowStartupLocation="CenterOwner"
        Icon="/images/Icon.ico">

    <Window.Resources>
        <Style TargetType="ListBoxItem">
            <Setter Property="Height" Value="100"/>
            <Setter Property="Margin" Value="5,3"/>
            <Setter Property="BorderBrush" Value="#DDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <DataTemplate x:Key="OrderTemplate">
            <Grid Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="200"/>
                </Grid.ColumnDefinitions>

                <!-- Левая часть -->
                <StackPanel Grid.Column="0">
                    <TextBlock FontSize="13" FontWeight="Bold">
                        <Run Text="Артикул заказа: " FontWeight="Bold"/>
                        <Run Text="{Binding Id}"/>
                    </TextBlock>

                    <TextBlock Margin="0,5,0,0">
                        <Run Text="Статус заказа: " FontWeight="Bold"/>
                        <Run Text="{Binding Status}"/>
                    </TextBlock>

                    <TextBlock Margin="0,5,0,0" TextWrapping="Wrap">
                        <Run Text="Адрес пункта выдачи: " FontWeight="Bold"/>
                        <Run Text="{Binding PickupPoint.Address}"/>
                    </TextBlock>

                    <TextBlock Margin="0,5,0,0">
                        <Run Text="Дата заказа: " FontWeight="Bold"/>
                        <Run Text="{Binding OrderDate, StringFormat=dd.MM.yyyy}"/>
                    </TextBlock>
                </StackPanel>

                <!-- Правая часть: Дата доставки -->
                <Border Grid.Column="1" Background="#F9F9F9" Margin="5" CornerRadius="5" HorizontalAlignment="Right" Width="180">
                    <StackPanel Margin="10" VerticalAlignment="Center">
                        <TextBlock Text="Дата доставки" FontSize="12" FontWeight="Bold" 
                                   TextAlignment="Center" HorizontalAlignment="Center"/>
                        <TextBlock FontSize="13" FontWeight="Bold" 
                                   TextAlignment="Center" HorizontalAlignment="Center" Margin="0,5,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="{Binding DeliveryDate, StringFormat=dd.MM.yyyy}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DeliveryDate}" Value="{x:Null}">
                                            <Setter Property="Text" Value="Не указана"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#7FFF00" Height="60">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Список заказов" FontSize="20" FontFamily="Times New Roman" 
                           FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,20,0"/>
                <Button x:Name="btnAddOrder" Content="Добавить заказ" Click="AddOrder_Click" 
                        Background="#00FA9A" Width="120" Visibility="Collapsed"/>
                <Button Content="Обновить" Click="Refresh_Click" Width="100" Background="#00FA9A"/>
            </StackPanel>
        </Border>

        <ListBox Grid.Row="1" x:Name="lbOrders" 
                 ItemTemplate="{StaticResource OrderTemplate}"
                 MouseDoubleClick="Order_DoubleClick"
                 Background="White"
                 BorderThickness="0"
                 ScrollViewer.CanContentScroll="True"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"/>

        <Border Grid.Row="2" Background="#7FFF00" Height="40">
            <TextBlock x:Name="txtStatus" Text="Готов" FontSize="12" FontFamily="Times New Roman" 
                       VerticalAlignment="Center" Margin="10,0"/>
        </Border>
    </Grid>
</Window>